# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored and loaded automatically by Next.js in dev.

# OpenRouter API key — powers the extract (Haiku) and narrow/match (Sonnet) stages.
# Get one at https://openrouter.ai/keys. Must start with "sk-or-".
# If unset, the pipeline falls back to deterministic keyword stubs so the UI still works.
OPENROUTER_API_KEY=

# Optional — override model IDs. Defaults are set in lib/extract.ts and lib/classifier.ts.
# OPENROUTER_EXTRACT_MODEL=anthropic/claude-haiku-4-5
# OPENROUTER_NARROW_MODEL=anthropic/claude-sonnet-4-6
# OPENROUTER_MATCH_MODEL=anthropic/claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Auth (NextAuth v5 / Auth.js) — single-operator credentials sign-in.
# -----------------------------------------------------------------------------

# Required: base64 of `username:password`.
#   $ printf 'operator:correct-horse' | base64
#   => b3BlcmF0b3I6Y29ycmVjdC1ob3JzZQ==
# Rotate by redeploying with a new value.
AUTH_BASIC_CREDENTIALS=

# Required: secret used to sign JWT session tokens. Any long random string.
#   $ openssl rand -base64 32
AUTH_SECRET=
